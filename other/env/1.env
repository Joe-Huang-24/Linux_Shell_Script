#!/bin/env bash

### test shell script env file ###

#loop_n=1
#n=0
#total_n=20

# Set values
INTERVAL=2
# Services check list
SERVICES=("ypbind" "sssd" "autofs" "nfs-utils" "ctxhdx" "ctxvda")

# Set color list
C_RESET='\e[0m'
C_RED='\e[1;31m'
C_GREEN='\e[1;32m'
C_YELLOW='\e[1;33m'
C_PURPLE='\e[1;35m'
C_CYAN='\e[1;36m'

# Set log msg color
log () { printf '%b%s\n' "$*"; }
msg_yellow () { log "${C_YELLOW}$*${C_RESET}"; }
msg_green () { log "${C_GREEN}$*${C_RESET}"; }
msg_red () { log "${C_RED}$*${C_RESET}"; }

log_service () { printf '%b%s\n' "$1"; }

ok () { log "$1"; }

err () { log "${C_RED}$*${C_RESET}"; }

section() {
    printf '\n========== %s ==========\n' "$1"
}


# sleep 2 function
stop_2s () {
        sleep $INTERVAL
}

# Get total memory function
get_memory_total() {
    awk '/MemTotal/ {printf "%.2f GiB", $2 / 1048576}' /proc/meminfo
}

# Get host ip function
get_ip_address () {
        hostname -I
}

# check system is systemd or not
get_service_command () {
        command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]
}

# Get service status
get_service_status () {
        local SERVICES=$1
        for s in ${SERVICES[@]}; do
                if get_service_command; then
                        systemctl is-active "$s" 2>/dev/null || echo "inactive"
                else
                        service "$s" status 2>/dev/null && echo "active" || echo "inactive"
                fi
        done
}

# check service main script
check_service () {
        local status
        for s in ${SERVICES[@]}; do
                status=$(get_service_status "$s")
                log "Service [$s] : $status"
        done
}

show_top_cpu_processes() {
    section "Top 5 CPU Processes"
    ps -eo pid,user,comm,%cpu,%mem --sort=-%cpu 2>/dev/null | head -n 6
}

