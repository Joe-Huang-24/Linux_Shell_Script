#!/bin/env bash

TOTAL_ROUNDS=20
INTERVAL=2
DISK_WARN_THRESHOLD=80
SERVICES=("ypbind" "autofs")


log() {
    printf '%s\n' "$1"
#       echo -e "/n$1"
}

section() {
    printf '\n========== %s ==========\n' "$1"
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

get_memory_total() {
    awk '/MemTotal/ {printf "%.2f GiB", $2 / 1048576}' /proc/meminfo
}

get_memory_usage() {
    free -h 2>/dev/null | awk '/^Mem:/ {print $3 " / " $2}'
}

get_swap_usage() {
    free -h 2>/dev/null | awk '/^Swap:/ {print $3 " / " $2}'
}

get_ip_addresses() {
    if command_exists hostname; then
        hostname -I 2>/dev/null | xargs
    fi
}

get_uptime_info() {
    if uptime -p >/dev/null 2>&1; then
        uptime -p
    else
        uptime
    fi
}

get_load_average() {
    awk '{print $1, $2, $3}' /proc/loadavg
}

get_boot_time() {
    who -b 2>/dev/null || true
}

get_yp_server() {
    if command_exists ypwhich; then
        ypwhich 2>/dev/null || echo "N/A"
    else
        echo "ypwhich command not found"
    fi
}

get_domain_name() {
    domainname 2>/dev/null || echo "N/A"
}

get_root_disk_usage() {
    df -hP / 2>/dev/null | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}'
}

show_disk_warnings() {
    local found=0

    while read -r fs size used avail usep mountp; do
        usep=${usep%\%}
        if [ "$usep" -ge "$DISK_WARN_THRESHOLD" ]; then
            log "Warning: Filesystem $fs mounted on $mountp is ${usep}% used"
            found=1
        fi
    done < <(df -hP 2>/dev/null | awk 'NR>1 && $1 ~ "^/dev/" {print $1, $2, $3, $4, $5, $6}')

    [ "$found" -eq 0 ] && log "Disk Usage Warning: None"
}

check_service_status() {
    local svc="$1"

    if command_exists systemctl; then
        systemctl is-active "$svc" 2>/dev/null || echo "inactive"
    elif command_exists service; then
        service "$svc" status >/dev/null 2>&1 && echo "active" || echo "inactive"
    else
        echo "unknown"
    fi
}

show_services_status() {
    local svc status
    for svc in "${SERVICES[@]}"; do
        status="$(check_service_status "$svc")"
        log "Service [$svc] : $status"
    done
}

show_top_cpu_processes() {
    section "Top 5 CPU Processes"
    ps -eo pid,user,comm,%cpu,%mem --sort=-%cpu 2>/dev/null | head -n 6
}

show_top_mem_processes() {
    section "Top 5 Memory Processes"
    ps -eo pid,user,comm,%cpu,%mem --sort=-%mem 2>/dev/null | head -n 6
}

show_system_info() {
    log "Hostname       : $(hostname)"
    log "Domain name    : $(get_domain_name)"
    log "YP Server      : $(get_yp_server)"
    log "IP Addresses   : $(get_ip_addresses)"
    log "Memory Total   : $(get_memory_total)"
    log "Memory Usage   : $(get_memory_usage)"
    log "Swap Usage     : $(get_swap_usage)"
    log "Load Average   : $(get_load_average)"
    log "Uptime         : $(get_uptime_info)"
    log "Boot Time      : $(get_boot_time)"
    log "Root Disk Usage: $(get_root_disk_usage)"
}

