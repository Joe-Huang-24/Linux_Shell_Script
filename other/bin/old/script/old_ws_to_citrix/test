#!/bin/bash

usage() {
    echo "Usage: $0 [-d DAYS] [-n NTH_DAY] [-h]"
    echo "  -a Extra Check Check All Server Information"
    echo "  -l log check Check backup status"
    echo "  -h           Show this help message"
    exit 0
}

service_check() {
	local service=("ypbind" "autofs")
	for i in ${service[@]}; do
		service $i status >> /dev/null 2>&1 && echo -e "\e[33mService $i is Active\e[0m" || echo -e "\e[31mService $i is Dead\e[0m"
	done
	exit 0
}

daily_backup() {
	/backup_sh/check_backup -d 2
}


while getopts "a:l:h" opt; do
    case $opt in
        a)
            service_check 
            ;;
        l)
            daily_backup
            ;;
        h)
            usage
            ;;
        *)
            usage
            ;;
    esac
done

