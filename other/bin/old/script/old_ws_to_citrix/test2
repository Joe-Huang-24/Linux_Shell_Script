#!/bin/bash

usage() {
    echo "Usage: $0 [-a] [-l] [-h]"
    echo "  -a    Check all server information (services: ypbind, autofs)"
    echo "  -l    Check backup status"
    echo "  -h    Show this help message"
    exit 0
}

show_srv_information() {
	local td=$(date +%Y-%m-%d)
	echo -e "\e[1;33mShow Server Basic Information\e[0m"
	echo -e "\n============ \e[1;36mStarting to check server information\e[1;33m [$(hostname)]\e[0m at \e[1;36m$(date +%Y/%m/%d)\e[0m ============\n"
	echo -e "\e[1;32mHostname: \e[1;33m$(hostname)\e[0m"
	echo -e "\e[1;32mCPU Model name: \e[1;33m$(grep 'model name' /proc/cpuinfo | uniq | awk -F ': ' '{print $2}')\e[0m"
	echo -e "\e[1;32mCPU Core: \e[1;33m$(grep -m 1 'cpu cores' /proc/cpuinfo | awk -F ': ' '{print $2}')\e[0m"
	echo -e "\e[1;32mMemory: \e[1;33m$(grep 'MemTotal' /proc/meminfo | awk '{printf "%.2f", $2 / 1048576}') GiB\e[0m"
	echo -e "\e[1;32mIP Addresses: \e[1;33m$(hostname -I | awk '{print $1}')\e[0m"
	echo -e "\e[1;32mOS: \e[1;33m$(cat /etc/redhat-release)\e[0m"
	echo -e "\e[1;32mOS Install Time: \e[1;33m$(rpm -qa basesystem --qf '%{installtime:date}\n')\e[0m"
	echo -e "\e[1;32mCitrix Release: \e[1;33m2203\e[0m"
	echo -e "\n"
}
	


service_check() {
    local services=("ypbind" "autofs")
    echo -e "\e[1;35mChecking Main Service YPBind and Autofs\e[0m"
    for i in "${services[@]}"; do
        if service "$i" status >> /dev/null 2>&1 ; then
            echo -e "\e[1;33mService $i is Active\e[0m"
        else
            echo -e "\e[1;31mService $i is Dead\e[0m"
        fi
    done
    echo
    echo
}

daily_backup() {
    if /backup_sh/check_backup -d 2; then
        echo -e "\e[32mBackup check completed successfully.\e[0m"
    else
        echo -e "\e[31mBackup check failed.\e[0m"
    fi
}

while getopts "alh" opt; do
    case $opt in
        a)
	    show_srv_information
            service_check
	    daily_backup
            exit 0
            ;;
        l)
            daily_backup
            exit 0
            ;;
        h)
            usage
            ;;
        *)
            usage
            ;;
    esac
done

# 如果沒有提供參數，則顯示使用說明
if [[ $# -eq 0 ]]; then
    usage
fi

