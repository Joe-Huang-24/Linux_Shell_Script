#!/bin/bash
set -uo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

readonly BASE_DIR="/mis_daily_check"
readonly FUNCTION_DIR="${BASE_DIR}/function"
readonly LOG_DIR="${BASE_DIR}/log"
readonly IPLIST_FILE="${FUNCTION_DIR}/iplist.txt"
readonly SERVICES_FILE="${FUNCTION_DIR}/services.txt"
readonly HOSTNAME_LC="$(hostname | tr '[:upper:]' '[:lower:]')"
readonly LOG_FILE="${LOG_DIR}/$(hostname)_$(date +%F-%H%M%S)_Daily_Check.log"

readonly C_RESET='\e[0m'
readonly C_RED='\e[1;31m'
readonly C_GREEN='\e[1;32m'
readonly C_YELLOW='\e[1;33m'
readonly C_PURPLE='\e[1;35m'
readonly C_CYAN='\e[1;36m'

msg()   { printf '%b\n' "$*"; }
info()  { msg "${C_CYAN}$*${C_RESET}"; }
title() { msg "${C_PURPLE}$*${C_RESET}"; }
ok()    { msg "${C_GREEN}$*${C_RESET}"; }
warn()  { msg "${C_YELLOW}$*${C_RESET}"; }
err()   { msg "${C_RED}$*${C_RESET}"; }

usage() {
    cat <<EOF
Usage: $0 [-a] [-i] [-l] [-p] [-h]

  -a    Show all check data
  -i    Check all server information (services: ypbind, autofs)
  -l    Check backup status
  -p    Ping hosts from ip list
  -h    Show this help message
EOF
    exit 0
}

show_srv_information() {
    local script="${FUNCTION_DIR}/show_srv_information"

    if [[ -x "$script" ]]; then
        "$script"
    else
        err "Cannot execute: $script"
        return 1
    fi
}

ping_hosts() {
    local host

    if [[ ! -r "$IPLIST_FILE" ]]; then
        err "Cannot read ip list: $IPLIST_FILE"
        return 1
    fi

    while IFS= read -r host || [[ -n "$host" ]]; do
        [[ -z "${host// }" ]] && continue
        [[ "$host" =~ ^[[:space:]]*# ]] && continue

        if ping -c 2 "$host" >/dev/null 2>&1; then
            :
            # 若要顯示正常主機，可改成：
            # ok "Server $host is up"
        else
            err "Server $host is down"
        fi
    done < "$IPLIST_FILE"
}

is_systemd() {
    command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]
}

check_service_status() {
    local service_name="$1"

    if is_systemd; then
        systemctl is-active --quiet "$service_name"
    else
        service "$service_name" status >/dev/null 2>&1
    fi
}

services_check() {
    local service_name
    local services=()

    if [[ ! -r "$SERVICES_FILE" ]]; then
        err "Cannot read services list: $SERVICES_FILE"
        return 1
    fi

    while IFS= read -r service_name || [[ -n "$service_name" ]]; do
        [[ -z "${service_name// }" ]] && continue
        [[ "$service_name" =~ ^[[:space:]]*# ]] && continue
        services+=("$service_name")
    done < "$SERVICES_FILE"

    title "Checking Main Services"

    for service_name in "${services[@]}"; do
        if check_service_status "$service_name"; then
            ok "Service $service_name is Active"
        else
            err "Service $service_name is Dead"
        fi
    done

    printf '\n'
}

daily_backup() {
    local backup_script="${FUNCTION_DIR}/${HOSTNAME_LC}_check_backup"

    if [[ ! -x "$backup_script" ]]; then
        warn "Backup checker not found or not executable: $backup_script"
        return 1
    fi

    if "$backup_script" -d 2; then
        ok "Backup check completed successfully."
    else
        err "Backup check failed."
        return 1
    fi
}

show_ntp_sync() {
    title "Show $(hostname) NTP SYNC."

    if command -v chronyc >/dev/null 2>&1; then
        chronyc sources -v
    elif command -v ntpq >/dev/null 2>&1; then
        ntpq -p
    else
        warn "chronyc or ntpq command not found."
    fi
}

del_log() {
    [[ -d "$LOG_DIR" ]] || return 0
    find "$LOG_DIR" -type f -name "*.log" -mmin +120 -delete
}

run_default() {
    info "If no parameters are specified, use default actions."

    show_srv_information
    services_check
    daily_backup
    show_ntp_sync
    del_log
}

main() {
    local do_info=0
    local do_backup=0
    local do_ping=0

    if [[ $# -eq 0 ]]; then
        mkdir -p "$LOG_DIR"
        {
            run_default
        } 2>&1 | tee -a "$LOG_FILE"
        return "${PIPESTATUS[0]}"
    fi

    while getopts ":ailph" opt; do
        case "$opt" in
            a)
                do_info=1
                do_backup=1
                ;;
            i)
                do_info=1
                ;;
            l)
                do_backup=1
                ;;
            p)
                do_ping=1
                ;;
            h)
                usage
                ;;
            \?)
                usage
                ;;
        esac
    done

    (( do_info )) && {
        show_srv_information
        services_check
    }

    (( do_backup )) && daily_backup
    (( do_ping )) && ping_hosts
}

main "$@"
