#!/bin/bash
set -uo pipefail

# ===== Color =====
YELLOW=$'\e[1;33m'
CYAN=$'\e[1;36m'
GREEN=$'\e[1;32m'
RED=$'\e[1;31m'
RESET=$'\e[0m'

# ===== Constant =====
HOSTNAME="$(hostname)"
TODAY="$(date +%Y/%m/%d)"
DISK_WARN_THRESHOLD=50
CITRIX_RELEASE="2203"

# ===== Function =====
show_info() {
    printf "%b%s: %b%s%b\n" "$GREEN" "$1" "$YELLOW" "$2" "$RESET"
}

section() {
    printf "\n============ %b%s%b at %b%s%b ============\n\n" \
        "$CYAN" "$1" "$RESET" "$GREEN" "$TODAY" "$RESET"
}

get_cpu_model() {
    awk -F ': ' '/model name/ {print $2; exit}' /proc/cpuinfo
}

get_memory_total() {
    awk '/MemTotal/ {printf "%.2f GiB", $2 / 1048576}' /proc/meminfo
}

get_os_release() {
    [[ -r /etc/redhat-release ]] && cat /etc/redhat-release || echo "Unknown"
}

get_os_install_time() {
    rpm -q basesystem --qf '%{installtime:date}\n' 2>/dev/null || echo "Unknown"
}

get_ip_addresses() {
    hostname -I 2>/dev/null | xargs
}

show_basic_information() {
    printf "%bShow Server Basic Information%b\n" "$YELLOW" "$RESET"
    printf "\n============ %bStarting to check server information%b [%s] at %b%s%b ============\n\n" \
        "$CYAN" "$YELLOW" "$HOSTNAME" "$CYAN" "$TODAY" "$RESET"

    show_info "Hostname" "$HOSTNAME"
    show_info "CPU Model" "$(get_cpu_model)"
    show_info "CPU Cores" "$(nproc)"
    show_info "Memory" "$(get_memory_total)"
    show_info "IP Addresses" "$(get_ip_addresses)"
    show_info "OS" "$(get_os_release)"
    show_info "OS Install Time" "$(get_os_install_time)"
    show_info "Citrix Release" "$CITRIX_RELEASE"
    show_info "Server UP Time" "$(uptime)"
    show_info "System Boot Time" "$(who -b)"
}

show_memory_usage() {
    section "Show Server Memory Usage"
    free -h
}

show_disk_usage() {
    section "Show Server HardDisk Device"

    df -hP | awk -v threshold="$DISK_WARN_THRESHOLD" '
    BEGIN {
        red="\033[0;31m";
        bright_red="\033[1;31m";
        reset="\033[0m";

        printf "%-20s %-10s %-10s %-10s %-10s %-20s\n",
               "Filesystem", "Size", "Used", "Avail", "Use%", "Mounted on";
    }
    NR > 1 && $1 ~ "^/dev/" {
        used=$5;
        gsub("%", "", used);

        if (used > threshold) {
            printf "%-20s %-10s %-10s %-10s %s%-9s%s %-20s\n",
                   $1, $2, $3, $4, red, $5, reset, $6;
        } else {
            printf "%-20s %-10s %-10s %-10s %-10s %-20s\n",
                   $1, $2, $3, $4, $5, $6;
        }

        if (used >= threshold) {
            printf "\n%sWarning: The partition \"%s\" (mounted on \"%s\") is almost full. Used: %s%s\n",
                   bright_red, $1, $6, $5, reset;
        }
    }'
}

show_user_resource_usage() {
    printf "\n%b##########################################%b\n" "$YELLOW" "$RESET"
    printf "User\t\tTotal CPU Usage\tTotal Memory Usage\n"

    ps -eo user=,%cpu=,%mem= | awk '
    BEGIN {
        green="\033[32m";
        reset="\033[0m";
    }
    {
        user=$1;
        cpu=$2;
        mem=$3;
        user_lc=tolower(user);

        if (user_lc ~ /a9812|nis|dpu|ooo/) {
            cpu_sum[user] += cpu;
            mem_sum[user] += mem;
        }
    }
    END {
        for (u in cpu_sum) {
            printf "%s%s%s\t%.1f%%\t\t%.1f%%\n",
                   green, u, reset, cpu_sum[u], mem_sum[u];
        }
    }' | sort
}

show_srv_main() {
    show_basic_information
    show_memory_usage
    show_disk_usage
    printf "\n"
    show_user_resource_usage
    printf "\n"
}

#show_srv_main "$@"
