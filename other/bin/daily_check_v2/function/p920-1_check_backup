#!/bin/bash 

echo -e "\e[1;33m\n****************************\e[0m";\
service ypbind status && echo -e "\n\033[33m$(hostname) YPbind service is Health\033[0m" || service ypbind restart;\
echo -e "\e[1;33m\n****************************\e[0m";\
free -h;\
echo -e "\e[1;33m\n****************************\e[0m";\
cat $(cat /etc/rsnapshot.conf | grep -w '^logfile' | awk '{print $2}') | tail -n 20;\
echo -e "\e[1;33m\n****************************\e[0m";\
exit


