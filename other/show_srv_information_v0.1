#!/bin/bash

clear && printf '\e[3J';

td=$(date +%Y-%m-%d)
td_time=$(date +%Y%m%d)-$(date +%T)
echo -e "\n"
echo -e "============ \e[1;36mStarting to check server information\e[1;33m [$(hostname)]\e[0m at\e[1;36m $(date +%Y/%m/%d)\e[0m ============\n"
echo -e "\e[1;32mHostname: \e[1;33m $(hostname)\e[0m"
echo -e "\e[1;32mCPU Model name: \e[1;33m $(grep 'model name' /proc/cpuinfo | uniq | awk -F : '{print $2}')\e[0m"
echo -e "\e[1;32mCPU Core: \e[1;33m $(grep 'cpu core' /proc/cpuinfo | uniq | awk -F : '{print $2}')\e[0m"
# echo -e "\e[1;32mCPU(s): \e[1;33m $(lscpu | grep '^CPU(s)' | awk '{print $2}')\e[0m"
echo -e "\e[1;32mMemory: \e[1;33m $(grep 'MemTotal' /proc/meminfo | awk -F ' ' '{print $2 / 1048576}') GiB\e[0m"
echo -e "\e[1;32mIP Addresses: \e[1;33m $(ifconfig | grep "inet addr" | awk '{print $2}' | cut -d ':' -f 2 | grep -v 127.0.0.1)\e[0m"
echo -e "\e[1;32mOS: \e[1;33m $(cat /etc/redhat-release)\e[0m"
echo -e "\e[1;32mOS Install Time:\e[1;33m$(rpm -qa basesystem --qf '%{installtime:date}\n')\e[0m"
# echo -e "\e[1;32mCPU(s) Useage: \e[1;33m$(top -bn1 | grep Cpu | awk '{print $2}')\e[0m"
# echo -e "\e[1;32mFree Memory: \e[1;33m$(vmstat -s | grep "free memory" | awk '{print $1 / 1048576}') MiB\e[0m"
echo -e "\n"

if [ "$1" == "extra" ]; then
    echo -e "============ \e[1;36mShow Server Current Status information\e[0m at \e[1;32m$(date +%Y/%m/%d)\e[0m ============\n"
    echo -e "\e[1;32mCPU Usage: \e[1;33m$(top -bn1 | grep Cpu | awk '{print $2}')%\e[0m"
    echo -e "\e[1;32mFree Memory: \e[1;33m$(vmstat -s | grep 'free memory' | awk '{printf "%.2f", $1 / 1048576}') MiB\e[0m"
else
    echo "************"
fi


echo -e "\n============ \e[1;36m Show Server HardDisk Device\e[0m at\e[1;32m $(date +%Y/%m/%d)\e[0m ============\n"
# df -h | grep ^'/dev/'
# df -h | grep ^'/dev/\|Filesystem'

df -h | awk '
BEGIN {
    # ANSI 顏色代碼
    red="\033[0;31m";
    reset="\033[0m";

    # 打印表頭，並對齊欄位
    printf "%-20s %-10s %-10s %-10s %-10s %-10s\n", "Filesystem", "Size", "Used", "Avail", "Use%", "Mounted on";
}
NR>1 {
    used=$5;  # 抓取 Used% 欄位
    gsub("%", "", used);  # 去掉 % 號，為數值比較做準備
    if (used > 50) {
        # 如果使用率超過 50%，將 Use% 欄位標記為紅色
        printf "%-20s %-10s %-10s %-10s %-10s %-10s\n", $1, $2, $3, $4, red $5 reset, $6;
    } else {
        # 保持 Use% 為正常顏色
        printf "%-20s %-10s %-10s %-10s %-10s %-10s\n", $1, $2, $3, $4, $5, $6;
    }
}'



echo -e "\n"

echo -e "============ \e[1;36mCheck Filesystem Space Useage\e[0m at\e[1;32m $(date +%Y/%m/%d)\e[0m ============\n"

####
echo -e "Filesystem\t\tSize\t\tMount on" ;

df -h | grep ^'/dev' | grep -v "^Filesystem" | while read output; do
    over_space=40
    usep=$(echo $output | awk '{ print $5 }' | sed 's/%//g')
    partition=$(echo $output | awk '{ print $1 }')
    mountpoint=$(echo $output | awk '{ print $6 }')

#   if [ "$usep" -ge "$over_space" ]; then
#	echo -e "Filesystem\t\tSize\t\tMount on\t\t" ; echo -e "\e[1;31m$partition\t\t$usep%\t\t$mountpoint\e[0m\n"
#   fi

    if [ "$usep" -ge "$over_space" ]; then
	echo -e "\e[1;31m$partition\t\t$usep%\t\t$mountpoint\e[0m"
    fi

done

echo -e "\n"

unset over_space usep partition td td_time
